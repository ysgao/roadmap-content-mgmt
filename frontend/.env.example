# Google Sheets data source (required for live data)
# Leave blank to use static JSON fallback (local dev only)
VITE_GOOGLE_SHEETS_ID=your-spreadsheet-id-here

# Keycloak PKCE auth (no client secret — public client)
VITE_KEYCLOAK_URL=https://keycloak.snomed.org/realms/snomed
VITE_KEYCLOAK_CLIENT_ID=roadmap-cms

# Google Apps Script Jira proxy Web App URL (deploy jira-proxy.gs as Web App)
VITE_JIRA_PROXY_URL=

# GitHub Pages base path (set to /repo-name/ when deploying to ihtsdo.github.io/repo-name/)
VITE_BASE_PATH=/
